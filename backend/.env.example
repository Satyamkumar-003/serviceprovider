# Copy this file to .env and fill in real values. Never commit .env.

# Port the Express server listens on (Render injects this automatically in prod)
PORT=5000

# Mongo connection string (MongoDB Atlas in production)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# Long random string used to sign JWTs. Rotate periodically. Required.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Comma-separated list of frontend origins allowed to call the API.
# Example for local + Netlify deploy:
# CLIENT_URL=http://localhost:3000,https://satyam2237003.netlify.app
CLIENT_URL=http://localhost:3000

# Optional: set to "production" on Render
NODE_ENV=development
